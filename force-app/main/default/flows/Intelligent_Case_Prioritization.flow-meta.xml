<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>65.0</apiVersion>
    <description>Intelligent Case Prioritization — KAN-12. Fires synchronously on Case Create. Invokes the Intelligent_Case_Prioritization flex prompt and writes Priority, Reason, and Type back to the Case. Falls back to a Task on failure.</description>
    <label>Intelligent Case Prioritization</label>
    <interviewLabel>Intelligent Case Prioritization {!$Flow.CurrentDateTime}</interviewLabel>
    <processType>AutoLaunchedFlow</processType>
    <runInMode>SystemModeWithoutSharing</runInMode>
    <status>Active</status>
    <environments>Default</environments>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>

    <!-- ── Variables ─────────────────────────────────────────────────────── -->
    <variables>
        <name>PromptResponseText</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
    </variables>

    <!-- ── Action Calls (grouped) ─────────────────────────────────────────── -->

    <!-- Step 2: Invoke Flex Prompt Template -->
    <actionCalls>
        <name>Generate_Case_Priority</name>
        <label>Generate Case Priority</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>Intelligent_Case_Prioritization</actionName>
        <actionType>generatePromptResponse</actionType>
        <connector>
            <targetReference>Parse_Agent_Triage_JSON</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Create_Triage_Failed_Task</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>Input:Case</name>
            <value>
                <elementReference>$Record</elementReference>
            </value>
        </inputParameters>
        <outputParameters>
            <assignToReference>PromptResponseText</assignToReference>
            <name>promptResponse</name>
        </outputParameters>
        <nameSegment>Intelligent_Case_Prioritization</nameSegment>
        <offset>0</offset>
    </actionCalls>

    <!-- Step 3: Call Apex — CaseAgentTriageJsonParser -->
    <actionCalls>
        <name>Parse_Agent_Triage_JSON</name>
        <label>Parse Agent Triage JSON</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>CaseAgentTriageJsonParser</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Check_Parse_Success</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Create_Triage_Failed_Task</targetReference>
        </faultConnector>
        <flowTransactionModel>Automatic</flowTransactionModel>
        <inputParameters>
            <name>json</name>
            <value>
                <elementReference>PromptResponseText</elementReference>
            </value>
        </inputParameters>
        <nameSegment>CaseAgentTriageJsonParser</nameSegment>
        <offset>0</offset>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </actionCalls>

    <!-- ── Decisions (grouped) ────────────────────────────────────────────── -->

    <!-- Step 1: Guard — Description not null -->
    <decisions>
        <name>Check_Case_Description</name>
        <label>Check Case Description</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Description</defaultConnectorLabel>
        <rules>
            <name>Description_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Description</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Generate_Case_Priority</targetReference>
            </connector>
            <label>Description Exists</label>
        </rules>
    </decisions>

    <!-- Step 4: Decision — isSuccess = true? -->
    <decisions>
        <name>Check_Parse_Success</name>
        <label>Check If Parsing is Success</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Failure</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Create_Triage_Failed_Task</targetReference>
        </defaultConnector>
        <rules>
            <name>Is_Success</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Parse_Agent_Triage_JSON.isSuccess</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Case_Priority</targetReference>
            </connector>
            <label>Is Success</label>
        </rules>
    </decisions>

    <!-- ── Record Creates (grouped) ──────────────────────────────────────── -->

    <!-- Fault Path — Create Task -->
    <recordCreates>
        <name>Create_Triage_Failed_Task</name>
        <label>Create AI Triage Failed Task</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Subject</field>
            <value>
                <stringValue>AI Triage Failed — Manual Review Required</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WhatId</field>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Open</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Priority</field>
            <value>
                <stringValue>High</stringValue>
            </value>
        </inputAssignments>
        <object>Task</object>
    </recordCreates>

    <!-- ── Record Updates (grouped) ──────────────────────────────────────── -->

    <!-- Step 5: Update Case — Priority, Reason, Type -->
    <recordUpdates>
        <name>Update_Case_Priority</name>
        <label>Update Case Priority, Reason and Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>Priority</field>
            <value>
                <elementReference>Parse_Agent_Triage_JSON.priority</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Reason</field>
            <value>
                <elementReference>Parse_Agent_Triage_JSON.reason</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Type</field>
            <value>
                <elementReference>Parse_Agent_Triage_JSON.caseType</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>

    <!-- ── Start ──────────────────────────────────────────────────────────── -->
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Case_Description</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Description</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Case</object>
        <recordTriggerType>Create</recordTriggerType>
        <scheduledPaths>
            <!-- KAN-13: Auto Assign Account and Contact — actions to be added -->
            <name>Scheduled_Path_KAN_13</name>
            <label>Auto Assign Account and Contact (KAN-13)</label>
            <offsetNumber>1</offsetNumber>
            <offsetUnit>Minutes</offsetUnit>
            <timeSource>RecordTriggerEvent</timeSource>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
    </start>

</Flow>
